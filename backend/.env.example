# Label Printer Hub — example environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets — .env is in .gitignore.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
PRINTER_HUB_DATABASE_URL=sqlite:////data/printer-hub.db

# ---------------------------------------------------------------------------
# Brother printers
# Fill in the IP address (or hostname) of each printer.
# Leave empty if the printer is not used.
# ---------------------------------------------------------------------------
PRINTER_HUB_QL820_HOST=
PRINTER_HUB_QL820_PORT=9100

PRINTER_HUB_PT750W_HOST=
PRINTER_HUB_PT750W_PORT=9100

# ---------------------------------------------------------------------------
# Printer backend + model selection (First-Print, Phase 17)
#
# PRINTER_HUB_PRINTER_BACKEND  — transport to use. Built-ins:
#   "ptouch"  Brother PT-Series via the ptouch library + SNMP preflight
#   "mock"    no-op in-memory printer for local dev without hardware
#   Third-party backends register via the label_hub.printer_backends
#   setuptools entry-points group.
#
# PRINTER_HUB_PRINTER_MODEL  — fallback model id when SNMP discovery is
#   off or unreachable. Resolved against ModelRegistry.
#
# PRINTER_HUB_PRINTER_DISCOVER_VIA_SNMP  — true (default): query the
#   printer's Brother private OID at startup and resolve the PJL
#   identification string to a driver via ModelRegistry.find_by_pjl.
#   Falls back to PRINTER_HUB_PRINTER_MODEL on SNMP failure.
#
# PRINTER_HUB_PRINTER_SNMP_COMMUNITY  — SNMPv2c community string. The
#   PT-P750W lives on the LAN/VPN, so v2c read-only access is fine.
#
# PRINTER_HUB_PRINTER_QUEUE_TIMEOUT_S  — graceful shutdown timeout for
#   the PrintQueue when the app stops.
# ---------------------------------------------------------------------------
PRINTER_HUB_PRINTER_BACKEND=ptouch
PRINTER_HUB_PRINTER_MODEL=PT-P750W
PRINTER_HUB_PRINTER_DISCOVER_VIA_SNMP=true
PRINTER_HUB_PRINTER_SNMP_COMMUNITY=public
PRINTER_HUB_PRINTER_QUEUE_TIMEOUT_S=30

# ---------------------------------------------------------------------------
# Webhook authentication
# Minimum 32 characters. Generate with:
#   openssl rand -hex 32
# ---------------------------------------------------------------------------
PRINTER_HUB_WEBHOOK_API_KEY=

# ---------------------------------------------------------------------------
# Snipe-IT integration (optional)
# ---------------------------------------------------------------------------
PRINTER_HUB_SNIPEIT_URL=
PRINTER_HUB_SNIPEIT_API_KEY=

# ---------------------------------------------------------------------------
# Grocy integration (optional)
# ---------------------------------------------------------------------------
PRINTER_HUB_GROCY_URL=
PRINTER_HUB_GROCY_API_KEY=

# ---------------------------------------------------------------------------
# Spoolman integration (no API key required)
# ---------------------------------------------------------------------------
PRINTER_HUB_SPOOLMAN_URL=

# ---------------------------------------------------------------------------
# SSE EventBus — resource limits
#
# PRINTER_HUB_SSE_QUEUE_SIZE      — per-subscriber asyncio.Queue depth.
#                                   Drop-oldest overflow when full. Must be > 0.
# PRINTER_HUB_SSE_HEARTBEAT_S     — keepalive comment interval (seconds) when
#                                   no events flow. Must be > 0.
# PRINTER_HUB_SSE_IDLE_TIMEOUT_S  — seconds of inactivity before the server
#                                   closes the SSE connection. Must be > 0.
# PRINTER_HUB_SSE_MAX_SUBSCRIBERS — max concurrent SSE clients per printer;
#                                   429 is returned when exceeded. Must be > 0.
# PRINTER_HUB_SSE_PROBE_INTERVAL_S — SNMP probe interval for
#                                   StatusProbeProducer (seconds). Must be > 0.
# ---------------------------------------------------------------------------
PRINTER_HUB_SSE_QUEUE_SIZE=32
PRINTER_HUB_SSE_HEARTBEAT_S=30
PRINTER_HUB_SSE_IDLE_TIMEOUT_S=300
PRINTER_HUB_SSE_MAX_SUBSCRIBERS=100
PRINTER_HUB_SSE_PROBE_INTERVAL_S=30

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PRINTER_HUB_SERVER_PORT=8090
PRINTER_HUB_LOG_LEVEL=INFO
